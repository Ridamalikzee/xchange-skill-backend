{
  "kind": "collectionType",
  "collectionName": "roles",
  "info": {
    "name": "role",
    "description": "Role - system roles for access control and permissions"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "users": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user.user",
      "mappedBy": "role"
    },
    "createdBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user"
    },
    "updatedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user"
    }
  }
}
