{
  "kind": "collectionType",
  "collectionName": "users",
  "info": {
    "name": "user",
    "description": "User entity - stores information about registered users"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "passwordHash": {
      "type": "password",
      "required": true,
      "private": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive", "suspended"],
      "default": "active"
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::role.role",
      "inversedBy": "users"
    },
    "profile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::profile.profile",
      "inversedBy": "user"
    },
    "skills": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::skill.skill",
      "mappedBy": "user"
    },
    "serviceRequestsRequested": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-request.service-request",
      "mappedBy": "requester"
    },
    "serviceRequestsProvided": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-request.service-request",
      "mappedBy": "provider"
    },
    "reviewsGiven": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "reviewer"
    },
    "reviewsReceived": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "reviewee"
    },
    "createdBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user"
    },
    "updatedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user"
    }
  }
}
